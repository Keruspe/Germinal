<schemalist>
    <schema id="org.gnome.Germinal" path="/org/gnome/Germinal/" gettext-domain="@GETTEXT_PACKAGE@">

    <key name="scrollback-lines" type="i">
      <default>65536</default>
      <summary>Number of lines to keep in the buffer</summary>
      <description>
        Maximum number of lines retained in the terminal scrollback buffer.
        Higher values use more memory.
      </description>
    </key>

    <key name="word-char-exceptions" type="s">
      <default>'-#%&amp;+,./;=?@\\_~\302\267'</default>
      <summary>List of ASCII punctuation characters that should be considered as part of a word when doing word-wise selection</summary>
      <description>
        Characters listed here are treated as word constituents when
        double-clicking to select a word. Useful for selecting URLs or
        paths without surrounding punctuation being excluded.
      </description>
    </key>

    <key name="font" type="s">
      <default>'DejaVu Sans Mono 8.5'</default>
      <summary>The font to use</summary>
      <description>
        Pango font description string for the terminal font, e.g.
        "Monospace 12" or "DejaVu Sans Mono 8.5".
      </description>
    </key>

    <key name="forecolor" type="s">
      <default>'#C64B9A'</default>
      <summary>The foreground color</summary>
      <description>
        Hex color string for the default text color in the terminal.
      </description>
    </key>

    <key name="backcolor" type="s">
      <default>'#212121'</default>
      <summary>The background color</summary>
      <description>
        Hex color string for the terminal background.
      </description>
    </key>

    <key name="palette" type="as">
      <!-- Stolen from sakura which stole it from gnome-terminal -->
      <default>
        [
          '#000000000000',
          '#cdcb00000000',
          '#0000cdcb0000',
          '#cdcbcdcb0000',
          '#1e1a908fffff',
          '#cdcb0000cdcb',
          '#0000cdcbcdcb',
          '#e5e2e5e2e5e2',
          '#4ccc4ccc4ccc',
          '#ffff00000000',
          '#0000ffff0000',
          '#ffffffff0000',
          '#46458281b4ae',
          '#ffff0000ffff',
          '#0000ffffffff',
          '#ffffffffffff'
        ]
      </default>
      <summary>The color palette</summary>
    </key>

    <key name="startup-command" type="s">
      <default>'tmux -u2 new -As0'</default>
      <summary>Command to launch at startup</summary>
      <description>
        Shell command to run when the terminal opens. Defaults to
        tmux, which provides session persistence, splits, and windows.
        Set to an empty string to launch the user's default shell instead.
      </description>
    </key>

    <key name="term" type="s">
      <default>'xterm-256color'</default>
      <summary>The value of the TERM env variable</summary>
      <description>
        Value exported as the TERM environment variable inside the terminal.
        Determines which terminfo entry programs use for cursor movement,
        color, and other capabilities.
      </description>
    </key>

    <key name="audible-bell" type="b">
      <default>false</default>
      <summary>Activate the audible bell</summary>
      <description>
        When enabled, the terminal emits an audible beep in response to
        the BEL control character. Disabled by default.
      </description>
    </key>

    <key name="decorated" type="b">
      <default>false</default>
      <summary>Display window decoration</summary>
      <description>
        When enabled, the window manager draws a title bar and border
        around the terminal window. Disabled by default for a minimal look.
      </description>
    </key>
  </schema>
</schemalist>
