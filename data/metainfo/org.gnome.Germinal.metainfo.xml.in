<component type="desktop-application">
  <id>org.gnome.Germinal</id>
  <launchable type="desktop-id">org.gnome.Germinal.desktop</launchable>
  <name>Germinal</name>
  <summary>Minimalist VTE-based terminal emulator</summary>
  <developer id="org.imagination-land">
    <name translatable="no">Marc-Antoine Perennou</name>
  </developer>
  <project_license>GPL-3.0-or-later</project_license>
  <metadata_license>CC-BY-SA-3.0</metadata_license>
  <project_group>GNOME</project_group>
  <content_rating type="oars-1.1" />
  <description>
    <p>
      Germinal is a minimalist terminal emulator aiming for simplicity.
      It starts maximized and integrates tmux for session management,
      giving you splits and windows without extra chrome.
    </p>
    <p>
      Settings for font, colors, scrollback length, and startup command
      are available through the built-in Preferences dialog.
    </p>
  </description>
  <url type="homepage">https://github.com/Keruspe/Germinal</url>
  <url type="bugtracker">https://github.com/Keruspe/Germinal/issues</url>
  <url type="donation">https://paypal.me/keruspe/</url>
  <url type="translate">https://github.com/Keruspe/Germinal</url>
  <update_contact>Marc-Antoine@Perennou.com</update_contact>
  <translation type="gettext">Germinal</translation>
  <releases>
    <release version="29" type="stable" date="2026-05-23">
      <description>
        <p>Changes:</p>
        <ul>
          <li>Built-in Preferences dialog (font, colors, palette, scrollback, word char exceptions, bell, decorations, startup command, TERM variable) with per-setting reset buttons</li>
          <li>Palette editor: 16 individual colour swatches arranged as Normal / Bright rows</li>
          <li>Default colour theme switched to Dracula</li>
        </ul>
      </description>
    </release>
    <release version="28" type="stable" date="2026-05-22">
      <description>
        <p>Changes:</p>
        <ul>
          <li>In-buffer text search (Ctrl+F to open, Escape to close, Ctrl+G/Enter for next match, Ctrl+Shift+G for previous match)</li>
          <li>Trackpad zoom support (Ctrl+scroll)</li>
          <li>Fix keyboard shortcut controller precedence</li>
        </ul>
      </description>
    </release>
    <release version="27" type="stable" date="2026-05-21">
      <description>
        <p>Major update. Changes:</p>
        <ul>
          <li>Ported to GTK4 and libadwaita</li>
          <li>Right-click menu ported to GMenuModel and GSimpleActionGroup</li>
          <li>Window title now uses VTE termprop API</li>
          <li>Scroll zoom gated to discrete wheel events only</li>
          <li>Minimum GLib 2.76, GTK 4.8, VTE 0.78, libadwaita 1.0</li>
        </ul>
      </description>
    </release>
  </releases>
</component>
